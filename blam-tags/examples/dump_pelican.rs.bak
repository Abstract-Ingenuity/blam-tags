use blam_tags::file::TagFile;
use blam_tags::render_method::RenderMethod;

fn main() {
    let path = "/Users/camden/Halo/halo3_mcc/tags/objects/levels/shared/pelican_crashed_h3/shaders/cr_pelican_hull.shader";
    let tag = TagFile::read(path).unwrap();
    let rm = RenderMethod::from_tag(&tag).unwrap();
    for p in &rm.parameters {
        println!("[{}] type={:?} real={} animated={}", p.name, p.parameter_type, p.real_parameter, p.animated_parameters.len());
        for (i, a) in p.animated_parameters.iter().enumerate() {
            print!("  anim[{i}] type={:?} func=", a.parameter_type);
            if let Some(f) = &a.function {
                println!("{:?} ftype={:?} eval(0,0)={}", f, f.function_type(), f.evaluate(0.0, 0.0));
            } else { println!("None"); }
        }
    }
}
